# OpenList 去重系统 环境变量配置参考
# 复制此文件为 .env 并填入实际值: cp .env.example .env
# .env 已被 .gitignore 忽略，不会提交到 Git

# === OpenList 连接 ===
OPENLIST_URL=http://192.168.123.7:5255
OPENLIST_USERNAME=admin
OPENLIST_PASSWORD=your_password_here
OPENLIST_TIMEOUT=30
OPENLIST_RETRY_MAX=3

# === 扫描配置 ===
SCANNER_WORKERS=32
SCANNER_QUEUE_SIZE=10000

# === 数据库 ===
DATABASE_PATH=data/media.db

# === TMDB (可选，不配置则禁用 TMDB 匹配) ===
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/w342
TMDB_CACHE_TTL=86400
TMDB_RATE_LIMIT=40
TMDB_MAPPING_PATH=./configs/mapping.yaml

# === 日志 ===
LOG_LEVEL=info
LOG_OUTPUT=stdout

# === 存储路径 (逗号分隔多个路径) ===
STORAGE_LOCAL_PATHS=/xunlei
STORAGE_QUARK_PATHS=/夸克网盘2/来自：分享/高评分电视剧,/夸克网盘2/来自：分享/电影,/夸克网盘2/来自：分享/电视剧
STORAGE_TIANYI_PATHS=/天翼云盘
